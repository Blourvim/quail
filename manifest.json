{
  "manifest_version": 3,
  "name": "quail",
  "version": "0.1.0",
  "description": "A Vim-like keyboard interface for Firefox",
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/indicator.js",
        "content/content.js",
        "content/hints.js"
      ],
      "css": [
        "styles/indicator.css",
        "styles/hints.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
